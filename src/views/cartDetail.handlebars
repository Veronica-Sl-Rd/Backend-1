<h1>Mi carrito</h1>

{{#if cart.products.length}}
    <ul>
    {{#each cart.products}}
        <li>
            {{this.product.title}} -
            ${{this.product.price}} -
            Cantidad: {{this.quantity}}
        </li>
    {{/each}}
    </ul>
{{else}}
    <p>El carrito está vacío</p>
{{/if}}

<a href="/products">⬅ Volver a productos</a>